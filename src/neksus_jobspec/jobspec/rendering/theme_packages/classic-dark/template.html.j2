<!DOCTYPE html>
<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>{{ title }} - NeksusJobSpec</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "spacing": {
                        "container-max-width": "720px",
                        "gutter": "1.5rem",
                        "section-gap": "4rem",
                        "margin-md": "2rem",
                        "element-gap": "1.5rem",
                        "margin-sm": "1rem",
                        "hairline": "1px",
                        "inline-padding": "1.5rem"
                    },
                    "fontFamily": {
                        "headline-md": ["Inter"],
                        "label-sm": ["Inter"],
                        "body-lg": ["Inter"],
                        "headline-lg": ["Inter"],
                        "display": ["Inter"],
                        "label-md": ["Inter"],
                        "body-md": ["Inter"],
                        "label-mono": ["ui-monospace, monospace"],
                        "label-caps": ["Inter"]
                    },
                    "fontSize": {
                        "headline-md": ["24px", {"lineHeight": "1.3", "fontWeight": "600"}],
                        "label-sm": ["12px", {"lineHeight": "1.2", "letterSpacing": "0.05em", "fontWeight": "600"}],
                        "body-lg": ["18px", {"lineHeight": "1.6", "fontWeight": "400"}],
                        "headline-lg": ["32px", {"lineHeight": "1.2", "letterSpacing": "-0.01em", "fontWeight": "600"}],
                        "display": ["48px", {"lineHeight": "1.1", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                        "label-md": ["14px", {"lineHeight": "1.4", "letterSpacing": "0.01em", "fontWeight": "500"}],
                        "body-md": ["16px", {"lineHeight": "1.6", "fontWeight": "400"}],
                        "headline-sm": ["18px", {"lineHeight": "1.4", "letterSpacing": "0", "fontWeight": "600"}],
                        "label-mono": ["14px", {"lineHeight": "1", "letterSpacing": "0.02em", "fontWeight": "500"}],
                        "label-caps": ["12px", {"lineHeight": "1", "letterSpacing": "0.05em", "fontWeight": "700"}]
                    }
                },
            },
        }
    </script>
<style>
        body {
            background-color: #141313;
            color: #e5e2e1;
            -webkit-font-smoothing: antialiased;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
{{ theme_css | safe }}
    </style>
</head>
<body class="font-body-md text-body-md bg-background text-on-surface" style="background:#141313;color:#e5e2e1;">
<header class="fixed top-0 left-0 w-full z-50 bg-surface/95 backdrop-blur-sm flex justify-center px-inline-padding border-b border-outline-variant">
<nav class="w-full max-w-container-max-width flex justify-between items-center h-16">
<span class="font-headline-md text-headline-md font-bold text-primary">{{ brand_name }}</span>
<div class="flex items-center gap-6">
<button class="cursor-pointer transition-all duration-200 bg-primary text-on-primary px-6 py-2 font-label-caps text-label-caps rounded-lg hover:opacity-90">
                {{ top_action_label }}
            </button>
</div>
</nav>
</header>
<main class="max-w-container-max-width mx-auto px-inline-padding pt-32 pb-section-gap">
<section class="mb-section-gap">
<h1 class="font-headline-lg text-headline-lg text-primary mb-4">{{ title }}</h1>
{% if subtitle %}<p class="font-body-lg text-body-lg leading-relaxed mb-8 text-on-surface">{{ subtitle }}</p>{% endif %}
<button class="bg-primary text-on-primary px-8 py-3 font-label-caps text-label-caps rounded-lg hover:opacity-90 transition-opacity">
            {{ apply_label }}
        </button>
</section>
{% if overview_body %}<div class="w-full h-hairline bg-outline-variant mb-element-gap"></div>
<section class="mb-section-gap">
<h2 class="font-label-caps text-label-caps text-on-surface-variant mb-element-gap uppercase tracking-widest">Overview</h2>
<p class="font-body-lg text-body-lg leading-relaxed text-on-surface">{{ overview_body }}</p>
</section>{% endif %}
{% if responsibilities %}<div class="w-full h-hairline bg-outline-variant mb-element-gap"></div>
<section class="mb-section-gap">
<h2 class="font-label-caps text-label-caps text-on-surface-variant mb-element-gap uppercase tracking-widest">Responsibilities</h2>
<ul class="space-y-4 ml-4">
{% for icon,title,body in responsibilities %}<li class="flex items-start gap-3"><span class="text-outline mt-1">—</span><span class="font-body-md text-body-md text-on-surface">{{ title }}{% if body %}: {{ body }}{% endif %}</span></li>{% endfor %}
</ul>
</section>{% endif %}
{% if requirements %}<div class="w-full h-hairline bg-outline-variant mb-element-gap"></div>
<section class="mb-section-gap">
<h2 class="font-label-caps text-label-caps text-on-surface-variant mb-element-gap uppercase tracking-widest">Requirements</h2>
<ul class="space-y-4 ml-4">
{% for item in requirements %}<li class="flex items-start gap-3"><span class="text-outline mt-1">—</span><span class="font-body-md text-body-md text-on-surface">{{ item }}</span></li>{% endfor %}
</ul>
</section>{% endif %}
{% if benefits %}<div class="w-full h-hairline bg-outline-variant mb-element-gap"></div>
<section class="mb-section-gap">
<h2 class="font-label-caps text-label-caps text-on-surface-variant mb-element-gap uppercase tracking-widest">Benefits</h2>
<div class="grid grid-cols-1 md:grid-cols-2 gap-6 ml-4">
{% for item in benefits %}<div class="flex items-start gap-3"><span class="text-outline mt-1">—</span><span class="font-body-md text-body-md text-on-surface">{{ item }}</span></div>{% endfor %}
</div>
</section>{% endif %}
{% if process_body or process_steps %}<div class="w-full h-hairline bg-outline-variant mb-element-gap"></div>
<section class="mb-section-gap">
<h2 class="font-label-caps text-label-caps text-on-surface-variant mb-element-gap uppercase tracking-widest">Application Process</h2>
{% if process_body %}<p class="font-body-md text-body-md mb-6 text-on-surface-variant">{{ process_body }}</p>{% endif %}
{% if process_steps %}<div class="space-y-6 ml-4">
{% for step in process_steps %}<div class="flex gap-4"><span class="font-label-mono text-label-mono text-outline">{{ '%02d'|format(loop.index) }}</span><div class="flex flex-col"><span class="font-headline-sm text-headline-sm text-on-surface">Step {{ loop.index }}</span><span class="font-body-md text-body-md text-on-surface-variant">{{ step }}</span></div></div>{% endfor %}
</div>{% endif %}
</section>{% endif %}
{% if contact_lines %}<div class="w-full h-hairline bg-outline-variant mb-element-gap"></div>
<section>
<h2 class="font-label-caps text-label-caps text-on-surface-variant mb-element-gap uppercase tracking-widest">Contact</h2>
<div class="ml-4">
{% for line in contact_lines %}{% if line.startswith('mailto:') %}<a class="text-primary font-bold hover:underline" href="{{ line }}">{{ line[7:] }}</a>{% else %}<p class="font-body-md text-body-md mb-2 text-on-surface">{{ line }}</p>{% endif %}{% endfor %}
</div>
</section>{% endif %}
</main>
<footer class="border-t border-outline-variant bg-surface-container-lowest py-section-gap">
<div class="max-w-container-max-width mx-auto px-inline-padding flex flex-col md:flex-row justify-between items-center gap-element-gap">
<span class="font-headline-sm text-headline-sm text-primary">{{ brand_name }}</span>
<div class="flex gap-8">
<a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors" href="#">Privacy Policy</a>
<a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors" href="#">Terms of Service</a>
<a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors" href="#">Cookie Policy</a>
</div>
<span class="font-label-caps text-label-caps text-on-surface-variant">{{ footer_text }}</span>
</div>
</footer>
</body></html>
