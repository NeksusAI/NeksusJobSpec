{% set hero = contract.component_groups.get('hero', []) %}
{% set hero_payload = hero[0].payload if hero else {} %}
{% set chips = contract.component_groups.get('meta_chips', []) %}
{% set chips_payload = chips[0].payload if chips else {} %}
{% set about = contract.component_groups.get('rich_text', []) %}
{% set about_payload = about[0].payload if about else {} %}
{% set grid = contract.component_groups.get('feature_grid', []) %}
{% set grid_payload = grid[0].payload if grid else {} %}
{% set req = contract.component_groups.get('list', []) %}
{% set req_payload = req[0].payload if req else {} %}
{% set ben = contract.component_groups.get('benefits', []) %}
{% set ben_payload = ben[0].payload if ben else {} %}
{% set process = contract.component_groups.get('application_process', []) %}
{% set process_payload = process[0].payload if process else {} %}
{% set contact = contract.component_groups.get('contact', []) %}
{% set contact_payload = contact[0].payload if contact else {} %}
{% set meta = contract.component_groups.get('meta_panel', []) %}
{% set meta_payload = meta[0].payload if meta else {} %}
{% set header_brand = contract.component_groups.get('header_brand', []) %}
{% set header_brand_payload = header_brand[0].payload if header_brand else {} %}
{% set header_actions = contract.component_groups.get('header_actions', []) %}
{% set header_actions_payload = header_actions[0].payload if header_actions else {} %}
{% set footer_brand = contract.component_groups.get('footer_brand', []) %}
{% set footer_brand_payload = footer_brand[0].payload if footer_brand else {} %}
{% set title = hero_payload.get('title') or contract.title %}
{% set brand_name = header_brand_payload.get('brand_name') or 'NeksusJobSpec' %}
{% set top_action_label = (header_actions_payload.get('actions') or [{'label': (contract.apply_label or 'Apply Now')}])[0].label %}
{% set subtitle = hero_payload.get('subtitle') or '' %}
{% if not subtitle %}{% set subtitle = (chips_payload.get('items', []) | map(attribute='value') | list)[:3] | join(' · ') %}{% endif %}
{% set apply_label = contract.apply_label or 'Apply Now' %}
{% set marker = contract.theme_config.get('requirements_marker', 'dash') %}
{% set list_marker = 'check' if marker == 'check' else '—' %}
{% set overview_body = about_payload.get('body') or contract.intro or '' %}
{% set responsibilities = [] %}{% for i in grid_payload.get('items', []) %}{% set _ = responsibilities.append((i.icon or 'hub', i.title, i.body)) %}{% endfor %}
{% set requirements = req_payload.get('items', []) %}
{% set benefits = [] %}{% for i in ben_payload.get('items', []) %}{% if i is mapping %}{% set _ = benefits.append(i.text) %}{% else %}{% set _ = benefits.append(i) %}{% endif %}{% endfor %}
{% set process_body = process_payload.get('body') or '' %}
{% set process_steps = process_payload.get('steps', []) %}
{% set contact_lines = [] %}
{% if contact_payload %}
{% for k in ['name','role','phone','mobile','email'] %}{% if contact_payload.get(k) %}{% set _ = contact_lines.append(contact_payload.get(k)) %}{% endif %}{% endfor %}
{% else %}
{% for k in ['contact_name','contact_role','contact_phone','contact_mobile','contact_email'] %}{% if meta_payload.get(k) %}{% set _ = contact_lines.append(meta_payload.get(k)) %}{% endif %}{% endfor %}
{% endif %}
{% set footer_text = footer_brand_payload.get('body') or (brand_name ~ ' • ' ~ title) %}
{% set footer_links = footer_brand_payload.get('links', []) %}
{% if not footer_links %}{% set footer_links = contract.theme_config.get('footer_links', []) %}{% endif %}
{% if not footer_links %}{% set footer_links = [{'label': 'Privacy Policy', 'url': '#'}, {'label': 'Terms of Service', 'url': '#'}, {'label': 'Cookie Policy', 'url': '#'}] %}{% endif %}

<!DOCTYPE html>
<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>{{ title }} - NeksusJobSpec</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "spacing": {
                        "element-gap": "1.5rem",
                        "hairline": "1px",
                        "container-max": "720px",
                        "inline-padding": "1rem",
                        "section-gap": "4rem"
                    },
                    "fontFamily": {
                        "headline-sm": ["Inter"],
                        "label-mono": ["ui-monospace, monospace"],
                        "label-caps": ["Inter"],
                        "body-md": ["Inter"],
                        "body-lg": ["Inter"],
                        "headline-md": ["Inter"],
                        "headline-lg": ["Inter"]
                    },
                    "fontSize": {
                        "headline-sm": ["18px", {"lineHeight": "1.4", "letterSpacing": "0", "fontWeight": "600"}],
                        "label-mono": ["14px", {"lineHeight": "1", "letterSpacing": "0.02em", "fontWeight": "500"}],
                        "label-caps": ["12px", {"lineHeight": "1", "letterSpacing": "0.05em", "fontWeight": "700"}],
                        "body-md": ["16px", {"lineHeight": "1.6", "letterSpacing": "0", "fontWeight": "400"}],
                        "body-lg": ["18px", {"lineHeight": "1.6", "letterSpacing": "0", "fontWeight": "400"}],
                        "headline-md": ["24px", {"lineHeight": "1.3", "letterSpacing": "-0.01em", "fontWeight": "600"}],
                        "headline-lg": ["32px", {"lineHeight": "1.2", "letterSpacing": "-0.02em", "fontWeight": "700"}]
                    }
                },
            },
        }
    </script>
<style>
        body {
            background-color: #ffffff;
            color: #1A1A1A;
            -webkit-font-smoothing: antialiased;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
{{ theme_css | safe }}
    </style>
</head>
<body class="font-body-md text-body-md">
<header class="fixed top-0 left-0 w-full z-50 bg-surface-bright/95 backdrop-blur-sm flex justify-center px-inline-padding border-b border-outline-variant dark:border-on-surface-variant">
<nav class="w-full max-w-container-max flex justify-between items-center h-16">
<span class="font-headline-md text-headline-md font-bold text-primary dark:text-on-primary-fixed">{{ brand_name }}</span>
<div class="flex items-center gap-6">
<button class="cursor-pointer transition-all duration-200 bg-primary text-on-primary px-6 py-2 font-label-caps text-label-caps rounded-lg hover:opacity-90">
                    {{ top_action_label }}
                </button>
</div>
</nav>
</header>
<main class="max-w-container-max mx-auto px-inline-padding pt-32 pb-section-gap">
<section class="mb-section-gap">
<h1 class="font-headline-lg text-headline-lg text-primary mb-4">{{ title }}</h1>
{% if subtitle %}<p class="font-body-lg text-body-lg leading-relaxed mb-8">{{ subtitle }}</p>{% endif %}
<button class="bg-primary text-on-primary px-8 py-3 font-label-caps text-label-caps rounded-lg hover:opacity-90 transition-opacity">
                {{ apply_label }}
            </button>
</section>
{% if overview_body %}<div class="w-full h-hairline bg-outline-variant mb-element-gap"></div>
<section class="mb-section-gap">
<h2 class="font-label-caps text-label-caps text-on-surface-variant mb-element-gap uppercase tracking-widest">{{ contract.labels.overview }}</h2>
<p class="font-body-lg text-body-lg leading-relaxed">{{ overview_body }}</p>
</section>{% endif %}
{% if responsibilities %}<div class="w-full h-hairline bg-outline-variant mb-element-gap"></div>
<section class="mb-section-gap">
<h2 class="font-label-caps text-label-caps text-on-surface-variant mb-element-gap uppercase tracking-widest">{{ contract.labels.responsibilities }}</h2>
<ul class="space-y-4 ml-4">
{% for icon,title,body in responsibilities %}<li class="flex items-start gap-3"><span class="text-outline mt-1">{{ list_marker }}</span><span class="font-body-md text-body-md">{{ title }}{% if body %}: {{ body }}{% endif %}</span></li>{% endfor %}
</ul>
</section>{% endif %}
{% if requirements %}<div class="w-full h-hairline bg-outline-variant mb-element-gap"></div>
<section class="mb-section-gap">
<h2 class="font-label-caps text-label-caps text-on-surface-variant mb-element-gap uppercase tracking-widest">{{ contract.labels.requirements }}</h2>
<ul class="space-y-4 ml-4">
{% for item in requirements %}<li class="flex items-start gap-3"><span class="text-outline mt-1">{{ list_marker }}</span><span class="font-body-md text-body-md">{{ item }}</span></li>{% endfor %}
</ul>
</section>{% endif %}
{% if benefits %}<div class="w-full h-hairline bg-outline-variant mb-element-gap"></div>
<section class="mb-section-gap">
<h2 class="font-label-caps text-label-caps text-on-surface-variant mb-element-gap uppercase tracking-widest">{{ contract.labels.benefits }}</h2>
<div class="grid grid-cols-1 md:grid-cols-2 gap-6 ml-4">
{% for item in benefits %}<div class="flex items-start gap-3"><span class="text-outline mt-1">{{ list_marker }}</span><span class="font-body-md text-body-md">{{ item }}</span></div>{% endfor %}
</div>
</section>{% endif %}
{% if process_body or process_steps %}<div class="w-full h-hairline bg-outline-variant mb-element-gap"></div>
<section class="mb-section-gap">
<h2 class="font-label-caps text-label-caps text-on-surface-variant mb-element-gap uppercase tracking-widest">{{ contract.labels.application_process }}</h2>
{% if process_body %}<p class="font-body-md text-body-md mb-6">{{ process_body }}</p>{% endif %}
{% if process_steps %}<div class="space-y-6 ml-4">
{% for step in process_steps %}<div class="flex gap-4"><span class="font-label-mono text-label-mono text-outline-variant">{{ '%02d'|format(loop.index) }}</span><div class="flex flex-col"><span class="font-headline-sm text-headline-sm">Step {{ loop.index }}</span><span class="font-body-md text-body-md text-on-surface-variant">{{ step }}</span></div></div>{% endfor %}
</div>{% endif %}
</section>{% endif %}
{% if contact_lines %}<div class="w-full h-hairline bg-outline-variant mb-element-gap"></div>
<section>
<h2 class="font-label-caps text-label-caps text-on-surface-variant mb-element-gap uppercase tracking-widest">{{ contract.labels.contact }}</h2>
<div class="ml-4">
{% for line in contact_lines %}{% if line.startswith('mailto:') %}<a class="text-primary font-bold hover:underline" href="{{ line }}">{{ line[7:] }}</a>{% else %}<p class="font-body-md text-body-md mb-2">{{ line }}</p>{% endif %}{% endfor %}
</div>
</section>{% endif %}
</main>
<footer class="border-t border-outline-variant dark:border-on-surface-variant bg-surface-container-lowest dark:bg-surface-container py-section-gap">
<div class="max-w-container-max mx-auto px-inline-padding flex flex-col md:flex-row justify-between items-center gap-element-gap">
<span class="font-headline-sm text-headline-sm text-primary dark:text-on-primary-fixed">{{ brand_name }}</span>
<div class="flex gap-8">{% for link in footer_links %}<a class="font-label-caps text-label-caps text-on-surface-variant dark:text-on-tertiary-fixed-variant hover:text-primary transition-colors" href="{{ link.url }}">{{ link.label }}</a>{% endfor %}</div>
<span class="font-label-caps text-label-caps text-on-surface-variant dark:text-on-tertiary-fixed-variant">{{ footer_text }}</span>
</div>
</footer>
</body></html>
